Connection_String=your_database_connection_string_here

JWT_SECRET_KEY=replace_with_strong_access_secret
JWT_REFRESH_SECRET_KEY=replace_with_strong_refresh_secret

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
OTP_EXPIRE_MINUTES=10
PASSWORD_RESET_EXPIRE_MINUTES=15

FRONTEND_URL=http://localhost:5173

# Upload storage and cleanup settings.
UPLOAD_STORAGE_DIR=D:/Zenteiq/Tasks/uploads
UPLOAD_SESSION_TTL_SECONDS=3600
UPLOAD_CLEANUP_INTERVAL_SECONDS=300

# Optional email validation tuning.
EMAIL_CHECK_DELIVERABILITY=false
